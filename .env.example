# Halo Configuration

# Gemini API (opcional - solo si quieres usar Gemini como fallback final)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 
# Gemini Model Configuration (opcional)
# Configurar modelos de Gemini por role o usar uno solo para todos
#
# OPCIÓN 1: Un solo modelo para todos los roles (más simple)
# GEMINI_MODEL=gemini-2.0-flash-exp
#
# OPCIÓN 2: Modelos específicos por role (más granular)
# GEMINI_MODELS=fallback:gemini-2.0-flash-exp,validator:gemini-1.5-flash,template:gemini-1.5-pro
#
# OPCIÓN 3: Variables individuales por role (máxima flexibilidad)
# GEMINI_FALLBACK_MODEL=gemini-2.0-flash-exp    # Role 1: Clasificador fallback
# GEMINI_VALIDATOR_MODEL=gemini-1.5-flash       # Role 2: Validador de calidad
# GEMINI_TEMPLATE_MODEL=gemini-1.5-pro          # Role 3: Maestro de templates
#
# Modelos disponibles:
# - gemini-2.0-flash-exp (recomendado, rápido y preciso)
# - gemini-1.5-flash (más económico, bueno para validación)
# - gemini-1.5-pro (más potente para tareas complejas)
#
# Default si no se configura: gemini-2.0-flash-exp para todos

# HuggingFace Token (opcional - para descargar modelos privados)
# HUGGINGFACE_TOKEN=your_hf_token_here
